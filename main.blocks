yout.Center</field><value name="str"><shadow type="text" id="oVZM+-D72YlL.2zsynH/"><field name="TEXT">She had to sit down here three months ago.</field></shadow></value><next><block type="game_show_long_text" id="jX=e;*klBD*FK53}FO11"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="H?-QjsMd^g#qE[|3rs8|"><field name="TEXT">She said she felt tired, and her breathing felt shallow.</field></shadow></value><next><block type="game_show_long_text" id="e.e8?VSwkO2zbiAE#APz"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="VTPP1cFa=YINOB3Z=jD%"><field name="TEXT">I told her we were just getting older.</field></shadow></value><next><block type="game_show_long_text" id="D_RWe4N9c^8;p9W(kH2N"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id=")#rjD}42K[TIBc;Je5@!"><field name="TEXT">I was an idiot.</field></shadow></value><next><block type="variables_set" id="Rh`|FuQ?3[;jX.agLyKx"><field name="VAR" id="o8.54#q^g=jkH%fG_7e1">lvl</field><value name="VALUE"><shadow type="math_number" id="r,r*ewr(6M[ln0TL;,--"><field name="NUM">3</field></shadow></value><next><block type="sound_play" id="Iz?Li6arx$5wZK8q#)8a"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="sound"><block type="variables_get" id="G@#ca%~bzL~GGfGq`j|f"><field name="VAR" id="gD-tAUWUoWhbl$xlLHL0">mySound</field></block></value><value name="pauseUntilDone"><shadow type="logic_boolean" id="a2d1sRCZ.jNXf0OIxC;$"><field name="BOOL">FALSE</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></next></block></next></block></statement></block></next></block></next></block></next></block></next></block></statement></block></statement></block></statement></block><block type="spriteshittile" id="Z;mB41PBjbWsx7C/H932" x="4528" y="6622"><value name="HANDL